# API Configuration
API_BASE_URL=https://api.peacefulhaven.lol
FRONTEND_URL=https://peacefulhaven.lol

# Minecraft Paths (UPDATE THESE!)
MINECRAFT_DIR=/home/opc/minecraft
SHOPKEEPERS_SAVE=/home/opc/minecraft/plugins/Shopkeepers/save.yml
SHOPKEEPERS_DB=/home/opc/minecraft/plugins/Shopkeepers/trades.db
PLAYTIME_DB=/home/opc/minecraft/plugins/YourPlaytimePlugin/playtime.db

# Database
DATABASE_URL=sqlite:////app/data/website.db

# Microsoft OAuth (GET THESE FROM AZURE)
MICROSOFT_CLIENT_ID=your_client_id_here
MICROSOFT_CLIENT_SECRET=your_client_secret_here
MICROSOFT_REDIRECT_URI=https://api.peacefulhaven.lol/auth/callback

# Security (GENERATE A RANDOM SECRET!)
SECRET_KEY=your_super_secret_key_here_change_this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Environment
ENVIRONMENT=production
